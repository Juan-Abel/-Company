<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Company - Proyecto</title>
  <style>
    body {
      margin: 0;
      font-family: 'Poppins', sans-serif;
      background: #fdf6f0;
      overflow-x: hidden;
    }

    /* Fondo con corazones */
    body::before {
      content: "💗 💕 💗 💕 💗 💕 💗 💕";
      position: fixed;
      width: 100%;
      height: 100%;
      opacity: 0.2;
      font-size: 40px;
      display: flex;
      flex-wrap: wrap;
      justify-content: space-around;
      align-items: center;
      z-index: -1;
    }

    .container {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      height: 100vh;
      text-align: center;
    }

    h1 {
      color: #d48aa3;
      font-size: 3em;
    }

    .btn {
      background: #e7a6b1;
      border: none;
      padding: 15px 25px;
      margin: 10px;
      border-radius: 20px;
      color: white;
      font-size: 18px;
      cursor: pointer;
      transition: 0.3s;
    }

    .btn:hover {
      background: #d46c8a;
    }

    .hidden {
      display: none;
    }

    .page {
      padding: 40px;
    }

    .content {
      display: flex;
      gap: 30px;
      flex-wrap: wrap;
      justify-content: center;
    }

    .letter {
      background: white;
      padding: 20px;
      border-radius: 15px;
      width: 300px;
      box-shadow: 0 5px 15px rgba(0,0,0,0.1);
    }

    .video {
      max-width: 400px;
    }

    video {
      width: 100%;
      border-radius: 15px;
    }

    .back {
      margin-top: 20px;
    }

  </style>
</head>
<body>

  <!-- Página principal -->
  <div id="home" class="container">
    <h1>Company 💕</h1>
    <button class="btn" onclick="showPage('carta')">Leer Carta</button>
    <button class="btn" onclick="showPage('video')">Ver Video</button>
  </div>

  <!-- Página carta -->
  <div id="carta" class="page hidden">
    <h1>Carta 💌</h1>
    <div class="letter">
      <p>
        Aquí puedes escribir tu carta ✨<br><br>
        Ejemplo:<br>
        Esta canción me recuerda a momentos especiales...
      </p>
    </div>
    <button class="btn back" onclick="goHome()">Volver</button>
  </div>

  <!-- Página video + letra -->
  <div id="video" class="page hidden">
    <h1>Company 🎶</h1>

    <div class="content">

      <div class="video">
        <!-- CAMBIA el archivo por tu video -->
        <video controls>
          <source src="video.mp4" type="video/mp4">
        </video>
      </div>

      <div class="letter">
        <p>
          Aquí puedes poner la letra de la canción ✨<br><br>
          (Pon fragmentos que te gusten)
        </p>
      </div>

    </div>

    <button class="btn back" onclick="goHome()">Volver</button>
  </div>

  <script>
    function showPage(page) {
      document.getElementById('home').classList.add('hidden');
      document.getElementById(page).classList.remove('hidden');
    }

    function goHome() {
      document.getElementById('home').classList.remove('hidden');
      document.getElementById('carta').classList.add('hidden');
      document.getElementById('video').classList.add('hidden');
    }
  </script>

</body>
</html>
